# ============================================================
# .env.local — Environment variables for Restaurant Finder
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — Required for favorites feature
# Get from: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Foursquare Places API — Optional but recommended for enrichment
# Get from: https://developer.foursquare.com → Create App
# Free tier: 1000 requests/day
FOURSQUARE_API_KEY=fsq3your-api-key-here

# Optional: Upstash Redis for production caching
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token
